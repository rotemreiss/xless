# Slack Incoming Webhook URL — destination for all XLESS alerts (required).
SLACK_INCOMING_WEBHOOK=

# imgbb API key — used to host bXSS screenshots (required for screenshots).
IMGBB_API_KEY=

# Bearer token protecting GET /xless-history and the /xless-mcp MCP server.
# Generate a strong random value, e.g.: openssl rand -hex 32
XLESS_HISTORY_API_TOKEN=

# Auto-injected by Vercel when you create/link a private Blob store (used for
# request-history persistence). Pull it locally with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# Local dev only: HTTP port for the Express server (defaults to 3000).
# PORT=3000
